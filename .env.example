# Configurações da Aplicação — Igreja São Sebastião (Express/TypeScript)
# Copie este arquivo para .env e preencha com suas configurações

# ===========================================
# OBRIGATÓRIAS
# ===========================================

# Conexão com PostgreSQL (Neon ou outro)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Chave secreta para sessões (mínimo 32 caracteres)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=<gere_uma_chave_forte_aqui>

# ===========================================
# ADMIN (obrigatórias em produção)
# ===========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<senha_forte>

# ===========================================
# CLOUDINARY (obrigatório para upload de imagens)
# ===========================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================================
# SMTP (opcional — email de resposta a mensagens)
# ===========================================
# Exemplo com Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=seu_email@dominio.com
# SMTP_PASS=sua_senha_ou_app_password
# SMTP_FROM=noreply@igrejasaosebastiao.com.br

# ===========================================
# APP
# ===========================================
PORT=5000
NODE_ENV=development
