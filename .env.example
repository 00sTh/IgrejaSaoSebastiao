# Configurações da Aplicação - Igreja São Sebastião
# Copie este arquivo para .env e preencha com suas configurações

# ===========================================
# CHAVE SECRETA (OBRIGATÓRIO)
# ===========================================
# Gere uma chave aleatória forte usando:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_super_segura_aqui

# ===========================================
# BANCO DE DADOS
# ===========================================
DATABASE_PATH=database.db

# ===========================================
# CONFIGURAÇÕES DE UPLOAD
# ===========================================
UPLOAD_FOLDER=static/uploads
MAX_FILE_SIZE=5242880

# ===========================================
# CREDENCIAIS DO ADMINISTRADOR
# ===========================================
# IMPORTANTE: Altere imediatamente após a primeira instalação!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sua_senha_segura_aqui

# ===========================================
# CONFIGURAÇÕES DO FLASK
# ===========================================
# DESENVOLVIMENTO: FLASK_ENV=development, DEBUG=True
# PRODUCAO: FLASK_ENV=production, DEBUG=False
#
# IMPORTANTE: NUNCA use DEBUG=True em producao!
FLASK_ENV=production
DEBUG=False

# ===========================================
# CONFIGURACOES DE EMAIL (SMTP)
# ===========================================
# Configure para enviar respostas por email
# Exemplo com Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# SMTP_HOST=smtp.seuservidor.com
# SMTP_PORT=587
# SMTP_USER=seu_email@dominio.com
# SMTP_PASS=sua_senha_ou_app_password
# SMTP_FROM=noreply@igrejasaosebastiao.com.br
